  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "^0.58.0",
    "@sinclair/typebox": "*"
  }
