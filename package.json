{
  "name": "pi-worktree",
  "version": "1.3.3",
  "description": "Git worktree management for Pi — create isolated workspaces with one command, optionally launch in cmux/tmux.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "git",
    "worktree",
    "cmux",
    "tmux"
  ],
  "files": [
    "extensions/worktree.ts",
    "skills/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/worktree.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
